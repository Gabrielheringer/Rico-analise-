# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://ais-dev-25hg36hwegd66vcpghsyjl-171134524183.us-east1.run.app"
URL_DO_APLICATIVO="https://ais-dev-25hg36hwegd66vcpghsyjl-171134524183.us-east1.run.app"

# JWT_SECRET: Secret for signing authentication tokens.
JWT_SECRET="YOUR_JWT_SECRET_HERE"

# MERCADO_PAGO_ACCESS_TOKEN: Your Mercado Pago Access Token (Secret Key)
MP_ACCESS_TOKEN="APP_USR-5922362960743721-022700-749384091a3e5d6373ef70509a30a067-3231099740"

# SUPABASE_URL: Your Supabase Project URL
SUPABASE_URL="https://your-project-id.supabase.co"

# SUPABASE_ANON_KEY: Your Supabase Project Anon Key
SUPABASE_ANON_KEY="your-anon-key"
